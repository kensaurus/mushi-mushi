{
  "name": "@mushi-mushi/plugin-crashlytics",
  "version": "0.1.0",
  "description": "Mushi Mushi plugin for Firebase Crashlytics — flags fixed reports via Remote Config and closes Crashlytics issues when Mushi applies a fix.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mushi-plugin-crashlytics": "./dist/server.js"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-crashlytics"
  },
  "keywords": ["mushi-mushi", "firebase", "crashlytics", "plugin", "mobile", "crash-reporting"]
}
