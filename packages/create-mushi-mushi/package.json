{
  "name": "create-mushi-mushi",
  "version": "0.5.7",
  "license": "MIT",
  "description": "Run `npm create mushi-mushi` to add the Mushi Mushi bug-reporting SDK to your existing project — the wizard auto-detects your framework (React, Vue, Svelte, Angular, React Native, Expo, Capacitor) and installs the right package.",
  "bin": {
    "create-mushi-mushi": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/cli": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/create-mushi-mushi"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "create",
    "scaffold",
    "init",
    "wizard",
    "bug-reporting",
    "user-feedback",
    "user-report",
    "feedback-widget",
    "session-replay",
    "screenshot",
    "shake-to-report",
    "react",
    "next.js",
    "nextjs",
    "vue",
    "nuxt",
    "svelte",
    "sveltekit",
    "angular",
    "react-native",
    "expo",
    "capacitor",
    "ionic",
    "sentry-companion",
    "sentry-alternative",
    "error-tracking",
    "ai-triage",
    "auto-fix"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  }
}
