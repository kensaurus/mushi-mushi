{
  "name": "@mushi-mushi/plugin-linear",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Reference Mushi Mushi plugin: create and bidirectionally sync Linear issues from Mushi reports.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mushi-plugin-linear": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-linear"
  },
  "author": "Kenji Sakuramoto",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "linear",
    "linear-app",
    "plugin",
    "issue-tracker",
    "issue-sync",
    "bidirectional-sync",
    "bug-reporting",
    "integration"
  ]
}
