{
  "name": "@mushi-mushi/plugin-rollbar",
  "version": "0.1.4",
  "description": "Mushi Mushi plugin for Rollbar — mirrors classified reports as Rollbar items and resolves them when Mushi applies a fix.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mushi-plugin-rollbar": "./dist/server.js"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-rollbar"
  },
  "keywords": [
    "mushi-mushi",
    "rollbar",
    "plugin",
    "error-tracking"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  },
  "homepage": "https://kensaur.us/mushi-mushi"
}
