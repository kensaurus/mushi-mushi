{
  "name": "@mushi-mushi/plugin-sentry",
  "version": "0.2.2",
  "license": "MIT",
  "description": "Reference Mushi Mushi plugin: mirror critical user-reported bugs into Sentry as events, and resolve the corresponding Sentry fingerprint when Mushi applies a fix.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mushi-plugin-sentry": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-sentry"
  },
  "author": "Kenji Sakuramoto",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "sentry",
    "sentry-companion",
    "plugin",
    "error-tracking",
    "observability",
    "bug-reporting",
    "integration"
  ]
}
