{
  "name": "@mushi-mushi/node",
  "version": "1.1.1",
  "description": "Server-side Node SDK — framework middleware (Express / Fastify / Hono), unhandled-rejection hook, OTel trace propagation, bidirectional Sentry correlation. The 'glue' SDK for server-originated reports.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.js"
      },
      "require": {
        "types": "./dist/express.d.cts",
        "default": "./dist/express.cjs"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/fastify.d.ts",
        "default": "./dist/fastify.js"
      },
      "require": {
        "types": "./dist/fastify.d.cts",
        "default": "./dist/fastify.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono.d.ts",
        "default": "./dist/hono.js"
      },
      "require": {
        "types": "./dist/hono.d.cts",
        "default": "./dist/hono.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/node"
  },
  "homepage": "https://kensaur.us/mushi-mushi",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "keywords": [
    "mushi-mushi",
    "bug-translation",
    "vibe-coding",
    "ai-debugging",
    "auto-fix",
    "mcp",
    "cursor",
    "node",
    "express",
    "fastify",
    "hono",
    "middleware",
    "unhandled-rejection",
    "opentelemetry",
    "otel",
    "sentry",
    "sentry-companion",
    "distributed-tracing",
    "ai-agent",
    "glue"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "index (core middleware + hooks)",
      "path": "dist/index.js",
      "limit": "8 KB"
    },
    {
      "name": "express adapter",
      "path": "dist/express.js",
      "limit": "1.5 KB"
    },
    {
      "name": "fastify adapter",
      "path": "dist/fastify.js",
      "limit": "1.25 KB"
    },
    {
      "name": "hono adapter",
      "path": "dist/hono.js",
      "limit": "1.25 KB"
    }
  ],
  "dependencies": {
    "@mushi-mushi/core": "workspace:^"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0",
    "express": ">=4.18.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@size-limit/file": "^12.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "eslint": "^10.4.1",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "engines": {
    "node": ">=20"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  }
}
