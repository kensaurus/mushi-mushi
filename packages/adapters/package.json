{
  "name": "@mushi-mushi/adapters",
  "version": "0.2.8",
  "license": "MIT",
  "description": "Bidirectional adapters — translate Datadog, Honeycomb, New Relic, Grafana Loki errors into Mushi reports (and vice versa). Each adapter is tree-shakeable from its own subpath import.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./datadog": {
      "types": "./dist/datadog.d.ts",
      "import": "./dist/datadog.js",
      "require": "./dist/datadog.cjs"
    },
    "./honeycomb": {
      "types": "./dist/honeycomb.d.ts",
      "import": "./dist/honeycomb.js",
      "require": "./dist/honeycomb.cjs"
    },
    "./new-relic": {
      "types": "./dist/new-relic.d.ts",
      "import": "./dist/new-relic.js",
      "require": "./dist/new-relic.cjs"
    },
    "./grafana-loki": {
      "types": "./dist/grafana-loki.d.ts",
      "import": "./dist/grafana-loki.js",
      "require": "./dist/grafana-loki.cjs"
    },
    "./sentry": {
      "types": "./dist/sentry.d.ts",
      "import": "./dist/sentry.js",
      "require": "./dist/sentry.cjs"
    },
    "./bugsnag": {
      "types": "./dist/bugsnag.d.ts",
      "import": "./dist/bugsnag.js",
      "require": "./dist/bugsnag.cjs"
    },
    "./rollbar": {
      "types": "./dist/rollbar.d.ts",
      "import": "./dist/rollbar.js",
      "require": "./dist/rollbar.cjs"
    },
    "./crashlytics": {
      "types": "./dist/crashlytics.d.ts",
      "import": "./dist/crashlytics.js",
      "require": "./dist/crashlytics.cjs"
    },
    "./firebase-analytics": {
      "types": "./dist/firebase-analytics.d.ts",
      "import": "./dist/firebase-analytics.js",
      "require": "./dist/firebase-analytics.cjs"
    },
    "./cloudwatch": {
      "types": "./dist/cloudwatch.d.ts",
      "import": "./dist/cloudwatch.js",
      "require": "./dist/cloudwatch.cjs"
    },
    "./opsgenie": {
      "types": "./dist/opsgenie.d.ts",
      "import": "./dist/opsgenie.js",
      "require": "./dist/opsgenie.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mushi-mushi/core": "workspace:^",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/node": "^22.20.0",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/adapters"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "homepage": "https://kensaur.us/mushi-mushi",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "adapters",
    "datadog",
    "honeycomb",
    "new-relic",
    "grafana-loki",
    "observability",
    "sentry-companion",
    "error-tracking",
    "bug-reporting",
    "llm-ops",
    "ai-triage",
    "auto-fix",
    "glue"
  ],
  "engines": {
    "node": ">=20"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  }
}
