{
  "name": "mushi-mushi",
  "version": "0.6.0",
  "license": "MIT",
  "description": "Ship a shake-to-report button and get AI-classified, deduped, ready-to-fix bug reports — one `npx mushi-mushi` command for React, Next.js, Vue, Nuxt, Svelte, SvelteKit, Angular, React Native, Expo, Capacitor, and vanilla JS. Companion to Sentry: catches the user-felt bugs crash trackers can't see. Wires into GitHub, Slack, Jira, Linear, PagerDuty, Langfuse, and any MCP-compatible AI agent (Cursor, Claude Code, Copilot).",
  "bin": {
    "mushi-mushi": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/cli": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/launcher"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "user-feedback",
    "session-replay",
    "screenshot",
    "shake-to-report",
    "sdk",
    "wizard",
    "setup",
    "init",
    "react",
    "next.js",
    "nextjs",
    "vue",
    "nuxt",
    "svelte",
    "sveltekit",
    "angular",
    "react-native",
    "expo",
    "capacitor",
    "ionic",
    "sentry-companion",
    "error-tracking",
    "ai-triage",
    "llm"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  }
}
