{
  "name": "@mushi-mushi/inventory-auth-runner",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Runs the inventory.yaml auth.scripted block via Playwright and seeds the resulting cookies into project_settings so the Mushi crawler + synthetic monitor can hit auth-gated routes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "mushi-mushi-auth": "./dist/run.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/inventory-auth-runner"
  },
  "homepage": "https://kensaur.us/mushi-mushi",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "keywords": [
    "mushi-mushi",
    "inventory",
    "auth",
    "playwright",
    "qa",
    "cookie-refresh"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "auth": "tsx src/run.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0"
  },
  "devDependencies": {
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/node": "^22.19.21",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "engines": {
    "node": ">=20"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  }
}
