{
  "name": "@mushi-mushi/react",
  "version": "0.5.0",
  "description": "React bindings for Mushi Mushi — Provider, hooks, and ErrorBoundary integration",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "user-feedback",
    "user-report",
    "feedback-widget",
    "react",
    "next.js",
    "nextjs",
    "provider",
    "hooks",
    "error-boundary",
    "session-replay",
    "screenshot",
    "shake-to-report",
    "sentry-companion",
    "sentry-alternative",
    "error-tracking",
    "ai-triage",
    "auto-fix",
    "llm-ops",
    "ai-agent",
    "sdk"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB"
    }
  ],
  "dependencies": {
    "@mushi-mushi/core": "workspace:^",
    "@mushi-mushi/web": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "author": "Kenji Sakuramoto",
  "engines": {
    "node": ">=20"
  }
}
