{
  "name": "@mushi-mushi/web",
  "version": "0.4.1",
  "description": "Mushi Mushi browser SDK — embeddable bug reporting widget with Shadow DOM isolation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./test-utils": {
      "import": {
        "types": "./dist/test-utils.d.ts",
        "default": "./dist/test-utils.js"
      },
      "require": {
        "types": "./dist/test-utils.d.cts",
        "default": "./dist/test-utils.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/web#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "user-feedback",
    "user-report",
    "feedback-widget",
    "browser-sdk",
    "widget",
    "shadow-dom",
    "screenshot",
    "session-replay",
    "shake-to-report",
    "vanilla-js",
    "vue",
    "svelte",
    "angular",
    "rage-click",
    "sentry-companion",
    "sentry-alternative",
    "error-tracking",
    "ai-triage",
    "auto-fix",
    "llm-ops",
    "ai-agent",
    "sdk"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "Core SDK bundle (minified + gzipped)",
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true
    },
    {
      "name": "Core SDK bundle (uncompressed)",
      "path": "dist/index.js",
      "limit": "60 KB"
    }
  ],
  "dependencies": {
    "@mushi-mushi/core": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@size-limit/file": "^12.1.0",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "author": "Kenji Sakuramoto",
  "engines": {
    "node": ">=20"
  }
}
