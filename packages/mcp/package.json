{
  "name": "@mushi-mushi/mcp",
  "mcpName": "io.github.kensaurus/mushi-mushi",
  "version": "0.16.1",
  "license": "MIT",
  "description": "MCP server for Mushi Mushi — triage user-felt bugs, pull evidence (screenshots, console logs, network requests), check blast radius, and dispatch fix PRs, all from your AI coding agent",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./branding": {
      "types": "./dist/branding.d.ts",
      "import": "./dist/branding.js"
    },
    "./feature-groups": {
      "types": "./dist/feature-groups.d.ts",
      "import": "./dist/feature-groups.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mushi-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean:types": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:smoke": "node scripts/smoke-stdio.mjs",
    "test:smoke-http": "node scripts/smoke-http.mjs",
    "test:e2e-live": "node scripts/e2e-live.mjs",
    "test:localhost": "node scripts/localhost-e2e.mjs",
    "check:catalog-sync": "node scripts/check-catalog-sync.mjs",
    "demo": "node scripts/demo-terminal-config.mjs",
    "inspector": "npx --yes @modelcontextprotocol/inspector@latest node ./dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mushi-mushi/core": "workspace:^",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.19.21",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/mcp"
  },
  "author": "Kenji Sakuramoto",
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "cursor",
    "cursor-plugin",
    "cursor-mcp",
    "claude",
    "claude-code",
    "bug-tracking",
    "error-monitoring",
    "bug-triage",
    "ai-triage",
    "agentic-fix",
    "auto-fix",
    "issue-tracker",
    "developer-tools",
    "ai-agent",
    "llm",
    "observability",
    "user-feedback"
  ],
  "engines": {
    "node": ">=20"
  }
}
