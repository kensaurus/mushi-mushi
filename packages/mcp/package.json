{
  "name": "@mushi-mushi/mcp",
  "version": "0.6.0",
  "license": "MIT",
  "description": "MCP server exposing Mushi Mushi reports to coding agents",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mushi-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean:types": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:smoke": "node scripts/smoke-stdio.mjs",
    "test:localhost": "node scripts/localhost-e2e.mjs",
    "demo": "node scripts/demo-terminal-config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mushi-mushi/core": "workspace:^",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.19.17",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/mcp"
  },
  "author": "Kenji Sakuramoto",
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "copilot",
    "agentic-fix",
    "ai-agent",
    "bug-reporting",
    "user-report",
    "ai-triage",
    "auto-fix",
    "llm",
    "llm-ops",
    "developer-tools",
    "sdk"
  ],
  "engines": {
    "node": ">=20"
  }
}
