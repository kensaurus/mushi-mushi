{
  "name": "@mushi-mushi/react-native",
  "version": "0.8.0",
  "license": "MIT",
  "description": "React Native SDK for Mushi Mushi — shake-to-report, bottom sheet widget, full context capture",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.19",
    "@react-navigation/native": ">=6",
    "expo-sensors": ">=13",
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "peerDependenciesMeta": {
    "@react-navigation/native": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "expo-sensors": {
      "optional": true
    }
  },
  "dependencies": {
    "@mushi-mushi/core": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "react": "^19.1.0",
    "react-native": "^0.79.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/react-native#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "user-feedback",
    "user-report",
    "feedback-widget",
    "react-native",
    "expo",
    "shake-to-report",
    "bottom-sheet",
    "screenshot",
    "session-replay",
    "offline-queue",
    "sentry-companion",
    "sentry-alternative",
    "error-tracking",
    "ai-triage",
    "auto-fix",
    "llm-ops",
    "ai-agent",
    "sdk"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  }
}
