{
  "patterns": [
    { "id": "ssn", "configKey": "ssns", "source": "\\b\\d{3}-\\d{2}-\\d{4}\\b", "replacement": "[REDACTED_SSN]" },
    { "id": "creditCard", "configKey": "creditCards", "source": "\\b(?:\\d[ -]*){12,18}\\d\\b", "replacement": "[REDACTED_CC]" },
    { "id": "awsAccessKey", "configKey": "secretTokens", "source": "\\b(?:AKIA|ASIA)[0-9A-Z]{16}\\b", "replacement": "[REDACTED_AWS_KEY]" },
    { "id": "awsSecretKey", "configKey": "secretTokens", "source": "(?:aws_secret_access_key|secret_access_key)[\"'\\s:=]+[A-Za-z0-9/+=]{40}\\b", "caseInsensitive": true, "replacement": "aws_secret_access_key=[REDACTED_AWS_SECRET]" },
    { "id": "stripeSecretKey", "configKey": "secretTokens", "source": "\\b(?:sk|rk)_(?:live|test)_[A-Za-z0-9]{24,}\\b", "replacement": "[REDACTED_STRIPE_KEY]" },
    { "id": "stripePublishableKey", "configKey": "secretTokens", "source": "\\bpk_(?:live|test)_[A-Za-z0-9]{24,}\\b", "replacement": "[REDACTED_STRIPE_PK]" },
    { "id": "slackToken", "configKey": "secretTokens", "source": "\\bxox[abpor]-[A-Za-z0-9-]{10,}\\b", "replacement": "[REDACTED_SLACK_TOKEN]" },
    { "id": "githubPatClassic", "configKey": "secretTokens", "source": "\\bghp_[A-Za-z0-9]{36}\\b", "replacement": "[REDACTED_GITHUB_PAT]" },
    { "id": "githubPatFineGrained", "configKey": "secretTokens", "source": "\\bgithub_pat_[A-Za-z0-9_]{80,}\\b", "replacement": "[REDACTED_GITHUB_PAT]" },
    { "id": "openaiKey", "configKey": "secretTokens", "source": "\\bsk-(?:proj-)?[A-Za-z0-9_-]{20,}\\b", "replacement": "[REDACTED_OPENAI_KEY]" },
    { "id": "anthropicKey", "configKey": "secretTokens", "source": "\\bsk-ant-[A-Za-z0-9_-]{20,}\\b", "replacement": "[REDACTED_ANTHROPIC_KEY]" },
    { "id": "googleKey", "configKey": "secretTokens", "source": "\\bAIza[0-9A-Za-z_-]{35}\\b", "replacement": "[REDACTED_GOOGLE_KEY]" },
    { "id": "jwt", "configKey": "secretTokens", "source": "\\beyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\b", "replacement": "[REDACTED_JWT]" },
    { "id": "email", "configKey": "emails", "source": "\\b[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}\\b", "replacement": "[REDACTED_EMAIL]" },
    { "id": "phone", "configKey": "phones", "source": "(?:\\+\\d{1,3}[\\s.-])?\\(?\\d{2,4}\\)?[\\s.-]\\d{3,4}[\\s.-]\\d{3,4}\\b", "replacement": "[REDACTED_PHONE]" },
    { "id": "ipv4", "configKey": "ipAddresses", "source": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b", "replacement": "[REDACTED_IP]", "defaultOn": false },
    { "id": "ipv6", "configKey": "ipv6", "source": "\\b(?:[A-Fa-f0-9]{1,4}:){2,7}[A-Fa-f0-9]{0,4}\\b", "replacement": "[REDACTED_IPV6]", "defaultOn": false }
  ]
}
