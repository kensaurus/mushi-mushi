{
  "name": "@mushi-mushi/plugin-pagerduty",
  "version": "0.2.7",
  "license": "MIT",
  "description": "Reference Mushi Mushi plugin: page on-call via PagerDuty when a critical bug is reported.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mushi-plugin-pagerduty": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.20.0",
    "eslint": "^10.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-pagerduty"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "pagerduty",
    "plugin",
    "incident-response",
    "on-call",
    "alerting",
    "bug-reporting",
    "integration"
  ],
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  },
  "homepage": "https://kensaur.us/mushi-mushi"
}
