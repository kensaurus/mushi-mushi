{
  "name": "@mushi-mushi/cli",
  "version": "0.26.0",
  "license": "MIT",
  "description": "CLI for Mushi Mushi — `mushi init` wizard installs the right SDK for your framework, plus report triage and pipeline health commands",
  "bin": {
    "mushi": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/node": "^22.20.0",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/cli"
  },
  "homepage": "https://kensaur.us/mushi-mushi",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-translation",
    "vibe-coding",
    "ai-debugging",
    "ai-triage",
    "auto-fix",
    "mcp",
    "cursor",
    "claude-code",
    "cli",
    "wizard",
    "setup",
    "init",
    "sdk",
    "next.js",
    "nextjs",
    "react",
    "vue",
    "nuxt",
    "svelte",
    "sveltekit",
    "angular",
    "react-native",
    "expo",
    "capacitor",
    "sentry-companion",
    "sentry-alternative",
    "ai-agent"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./init": {
      "import": {
        "types": "./dist/init.d.ts",
        "default": "./dist/init.js"
      }
    },
    "./detect": {
      "import": {
        "types": "./dist/detect.d.ts",
        "default": "./dist/detect.js"
      }
    },
    "./wizard-args": {
      "import": {
        "types": "./dist/wizard-args.d.ts",
        "default": "./dist/wizard-args.js"
      }
    },
    "./version": {
      "import": {
        "types": "./dist/version.d.ts",
        "default": "./dist/version.js"
      }
    }
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  }
}
