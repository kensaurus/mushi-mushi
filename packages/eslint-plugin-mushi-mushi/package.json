{
  "name": "eslint-plugin-mushi-mushi",
  "version": "0.2.1",
  "description": "ESLint rules that catch the dominant agentic-coding failure modes — empty handlers (Gate 1) and mock-data leaks into production paths (Gate 2). Designed to slot into the Mushi Mushi v2 CI Gate pipeline.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./recommended": {
      "import": {
        "types": "./dist/recommended.d.ts",
        "default": "./dist/recommended.js"
      },
      "require": {
        "types": "./dist/recommended.d.cts",
        "default": "./dist/recommended.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/eslint-plugin-mushi-mushi"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/master/packages/eslint-plugin-mushi-mushi#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "mushi-mushi",
    "agentic-coding",
    "vibe-coding",
    "dead-code",
    "mocks"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript-eslint/utils": "^8.59.1",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "author": "Kenji Sakuramoto",
  "engines": {
    "node": ">=20"
  }
}
