{
  "name": "@mushi-mushi/angular",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Angular SDK for Mushi Mushi — NgModule, injectable service, global ErrorHandler",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/core": ">=17"
  },
  "dependencies": {
    "@mushi-mushi/core": "workspace:*"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/angular"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/angular#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "sdk"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module"
}
