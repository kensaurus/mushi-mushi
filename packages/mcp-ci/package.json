{
  "name": "@mushi-mushi/mcp-ci",
  "version": "0.1.0",
  "description": "GitHub Action entrypoint for running Mushi Mushi MCP tools in CI — trigger judge, dispatch fixes, gate merges on classification coverage.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mushi-mcp-ci": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "files": ["dist", "action.yml", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/mcp-ci"
  },
  "keywords": ["mushi-mushi", "mcp", "github-action", "ci", "dispatch-fix"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.0"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2"
  },
  "author": "Kenji Sakuramoto"
}
