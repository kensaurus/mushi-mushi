{
  "name": "@mushi-mushi/plugin-sdk",
  "version": "0.7.0",
  "license": "MIT",
  "description": "TypeScript SDK for building third-party Mushi Mushi plugins (webhook handlers + signature verification + typed events).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    }
  },
  "bin": {
    "mushi-plugin": "./dist/dev-cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "eslint": "^10.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "express": ">=4",
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-sdk"
  },
  "author": "Kenji Sakuramoto",
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "plugin-sdk",
    "webhooks",
    "webhook-handler",
    "signature-verification",
    "express",
    "hono",
    "bug-tracking",
    "integrations",
    "sdk"
  ],
  "engines": {
    "node": ">=20"
  }
}
