{
  "name": "@mushi-mushi/plugin-sdk",
  "version": "0.3.0",
  "license": "MIT",
  "description": "TypeScript SDK for building third-party Mushi Mushi plugins (webhook handlers + signature verification + typed events).",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/express.js",
      "require": "./dist/express.cjs",
      "types": "./dist/express.d.ts"
    },
    "./hono": {
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs",
      "types": "./dist/hono.d.ts"
    }
  },
  "bin": {
    "mushi-plugin": "./dist/dev-cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "express": ">=4",
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-sdk"
  },
  "author": "Kenji Sakuramoto",
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "plugin-sdk",
    "webhooks",
    "webhook-handler",
    "signature-verification",
    "express",
    "hono",
    "bug-tracking",
    "integrations",
    "sdk"
  ]
}
