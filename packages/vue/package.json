{
  "name": "@mushi-mushi/vue",
  "version": "0.9.0",
  "license": "MIT",
  "description": "Vue 3 SDK for Mushi Mushi — plugin, composables, error handler integration",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "@mushi-mushi/core": "workspace:^",
    "@mushi-mushi/web": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/vue#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "user-feedback",
    "user-report",
    "feedback-widget",
    "vue",
    "vue3",
    "nuxt",
    "plugin",
    "composables",
    "session-replay",
    "screenshot",
    "shake-to-report",
    "sentry-companion",
    "sentry-alternative",
    "error-tracking",
    "ai-triage",
    "auto-fix",
    "llm-ops",
    "ai-agent",
    "sdk"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  }
}
