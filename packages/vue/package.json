{
  "name": "@mushi/vue",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Vue 3 SDK for Mushi Mushi — plugin, composables, error handler integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "echo 'no tests yet'",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "@mushi/core": "workspace:*"
  },
  "devDependencies": {
    "@mushi/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.0"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/vue#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "bug-reporting",
    "sdk"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module"
}
