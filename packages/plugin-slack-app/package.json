{
  "name": "@mushi-mushi/plugin-slack-app",
  "version": "0.1.0",
  "license": "MIT",
  "description": "First-party Slack App plugin (not an Incoming Webhook) for Mushi Mushi — OAuth install, Slash commands (/mushi), interactive buttons, and real-time event subscriptions.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "plugin.json", "manifest.json"],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-slack-app"
  },
  "author": "Kenji Sakuramoto",
  "homepage": "https://github.com/kensaurus/mushi-mushi/tree/main/packages/plugin-slack-app#readme",
  "bugs": { "url": "https://github.com/kensaurus/mushi-mushi/issues" },
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "keywords": ["mushi-mushi", "plugin", "slack", "slack-app", "oauth", "slash-commands", "interactive"]
}
