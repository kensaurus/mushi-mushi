{
  "name": "@mushi-mushi/plugin-slack-app",
  "version": "0.2.6",
  "license": "MIT",
  "description": "First-party Slack App plugin (not an Incoming Webhook) for Mushi Mushi — OAuth install, Slash commands (/mushi), interactive buttons, and real-time event subscriptions.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "plugin.json",
    "manifest.json",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mushi-mushi/plugin-sdk": "workspace:^"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@types/node": "^22.19.21",
    "eslint": "^10.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "packages/plugin-slack-app"
  },
  "author": "Kenji Sakuramoto (https://bsky.app/profile/mushimushi.dev)",
  "homepage": "https://kensaur.us/mushi-mushi",
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "mushi-mushi",
    "plugin",
    "slack",
    "slack-app",
    "oauth",
    "slash-commands",
    "interactive"
  ],
  "engines": {
    "node": ">=20"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kensaurus"
  }
}
