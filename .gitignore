# Dependencies
node_modules/
.pnpm-store/

# Build
dist/
*.tsbuildinfo
.next/

# Turbo
.turbo/

# Environment
.env
.env.local
.env.*.local
apps/admin/.env

# Supabase local state
**/supabase/.temp/

# IDE
.vscode/
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test / coverage
coverage/
.nyc_output/

# Debug
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Playwright
.playwright-mcp/
test-results/
playwright-report/

# Screenshots — never commit ad-hoc test screenshots into the repo root.
# Real product screenshots belong in docs/screenshots/ and are explicitly
# allow-listed below.
screenshots/
!docs/screenshots/
*.png
!docs/**/*.png
!apps/docs/public/**/*.png
!apps/admin/public/**/*.png
!packages/**/assets/**/*.png

# Windows shells sometimes leave behind a literal `nul` file when commands
# redirect to NUL on the wrong shell. Always ignore it.
nul

# Misc
*.tgz
.eslintcache
.cache/

# Temporary edge-function payload bundles produced by scripts/build-edge-payload.mjs
.tmp-deploy/

# Archive holding-pens for ad-hoc audit screenshots (Wave I/J/K). Kept out of
# git so they can't grow unbounded; the canonical product screenshots live in
# docs/screenshots/ and the historical audit reports in docs/audit-* still
# reference these paths but the rendered docs no longer require the assets.
audit-after/
audit-before/
audit-after-wave-*/

# Sentry
.sentryclirc
# Sourcemaps must never be served from the public S3 bucket. The Vite plugin
# already deletes them after upload (apps/admin/vite.config.ts), this is
# belt-and-suspenders so a stray local build can't accidentally commit one.
apps/admin/dist/**/*.map
