# =============================================================================
# Mushi Mushi — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For self-hosted deployment, see deploy/.env.example for Docker-specific vars.

# --- Supabase (required for backend) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- LLM Providers (required for classification pipeline) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI fallback when Anthropic is down
OPENAI_API_KEY=

# --- Admin Console (Vite) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_URL=https://your-project-ref.supabase.co/functions/v1/api

# --- LLM Observability (optional) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Self-Hosted Only (see deploy/.env.example for full list) ---
# POSTGRES_PASSWORD=mushimushi
# JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# DOMAIN=mushi.example.com

# --- Fix Agent (optional, for agentic auto-fix) ---
# GITHUB_TOKEN=ghp_your_token_here

# --- Sentry (error monitoring; optional) ---------------------------------------
# Two Sentry projects power this stack:
#   mushi-mushi-admin  ← browser bundle (admin console)
#   mushi-mushi-server ← Supabase Edge Functions (Deno)
#
# DSNs are designed to be public, so it is safe to ship them in the bundle.
# We still source them from env to keep them out of forks' build logs.
# SENTRY_AUTH_TOKEN is a maintainer-only secret used to upload sourcemaps and
# tag releases — it must NEVER be committed.
SENTRY_ORG=sakuramoto
SENTRY_PROJECT_ADMIN=mushi-mushi-admin
SENTRY_PROJECT_SERVER=mushi-mushi-server

# Browser DSN (admin console). Surfaced to client via Vite at build time.
VITE_SENTRY_DSN=

# Edge Functions DSN. In production set with `supabase secrets set SENTRY_DSN_SERVER=...`
SENTRY_DSN_SERVER=

# Required only for sourcemap upload + release tagging (CI: GitHub Secret).
SENTRY_AUTH_TOKEN=

# --- Stripe (optional; required for hosted Mushi Cloud billing) -----------------
# Provisioned by `node scripts/stripe-bootstrap.mjs` once STRIPE_SECRET_KEY is set.
# All seven STRIPE_* secrets must be pushed with `supabase secrets set` for the
# `api` and `stripe-webhooks` Edge Functions to talk to Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_REPORTS_ID=
STRIPE_METER_FIXES_ID=
STRIPE_PRICE_STARTER_BASE=
STRIPE_PRICE_STARTER_OVERAGE=
STRIPE_PRICE_PRO_BASE=
STRIPE_PRICE_PRO_OVERAGE=
# Set to `true` once you flip Stripe out of test mode. Drives the Stripe
# Dashboard deep-links in operator notifications.
STRIPE_LIVEMODE=false

# --- Operator notifications (optional; recommended for hosted) -----------------
# When a paid customer subscribes, fails a payment, cancels, or opens a support
# ticket, the `stripe-webhooks` and `api` Edge Functions push a rich message to
# whichever of these is set. Both can be enabled simultaneously (e.g. Slack for
# the team channel + Discord for your phone). No-ops if both are unset.
#
# Slack: docs.slack.dev/messaging/sending-messages-using-incoming-webhooks/
OPERATOR_SLACK_WEBHOOK_URL=
# Discord: server settings → integrations → webhooks → "New Webhook"
OPERATOR_DISCORD_WEBHOOK_URL=

# --- Customer support (optional) ----------------------------------------------
# The address surfaced on the BillingPage "Need help?" panel and Stripe
# Checkout `custom_text`. Defaults to support@mushimushi.dev for the hosted
# product; self-hosters MUST override this.
SUPPORT_EMAIL=
SUPPORT_URL=
