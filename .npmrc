strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=false
onlyBuiltDependenciesFile=

# ---------------------------------------------------------------------------
# Supply-chain hardening (npm CLI)
#
# These settings kick in when a contributor uses `npm install` directly
# (e.g. inside `examples/` or when scaffolding via `npx mushi-mushi` in a
# fresh repo). The pnpm-equivalent settings live in `pnpm-workspace.yaml`
# and are what `pnpm install --frozen-lockfile` honours in CI.
#
# WHY: post-Axios (March 2026) and Shai-Hulud (September 2025), the standard
# lesson is that newly-published versions are the riskiest. Cooling them off
# for 7 days closes the window most attackers operate in (Axios was
# detected and removed within ~5 hours; a 7-day delay would have blocked
# every recent publicly-disclosed npm supply-chain attack outright).
# Source: https://www.armorcode.com/blog/defending-against-npm-supply-chain-attacks-a-practical-guide
#
# SOURCE: https://docs.npmjs.com/cli/v11/using-npm/config#min-release-age
# Type per the npm docs is a Number (days), so `7d` would be ignored — use
# the bare integer.
#
# Requirements: npm >= 11.6.0. Older npm CLIs silently ignore unknown
# keys, so this is safe to commit even if a contributor uses an older npm.
# CI is on Node 24 / npm 11.5.1+ already; the launcher bin runs under the
# user's installed npm, where the cooldown is a no-op until they upgrade.
# ---------------------------------------------------------------------------
min-release-age=7
