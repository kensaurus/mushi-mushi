# Mushi SDK — app developer credentials
# Copy to .env.local (Vite) or .env (Next.js) in your app repo.
# Run `npx mushi-mushi` to auto-detect framework and write these for you.

VITE_MUSHI_PROJECT_ID=your_project_id
VITE_MUSHI_API_KEY=mushi_your_report_write_key
VITE_MUSHI_API_ENDPOINT=https://your-project.supabase.co/functions/v1/api

# Next.js uses NEXT_PUBLIC_MUSHI_* instead of VITE_MUSHI_*.
# MCP / CLI use MUSHI_PROJECT_ID + MUSHI_API_KEY (separate mcp:read or mcp:write key).
