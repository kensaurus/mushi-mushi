{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kensaur.us/mushi-mushi/schemas/fix-result-2.0.json",
  "title": "Mushi Mushi FixResult",
  "type": "object",
  "required": [
    "success",
    "branch",
    "filesChanged",
    "linesChanged",
    "summary"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "branch": {
      "type": "string"
    },
    "prUrl": {
      "type": "string",
      "format": "uri"
    },
    "filesChanged": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linesChanged": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "string"
    },
    "error": {
      "type": "string"
    }
  }
}
