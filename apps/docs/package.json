{
  "name": "@mushi-mushi/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Mushi Mushi documentation site (Nextra v4 + Next.js App Router)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "node ../../scripts/sync-docs-screenshots.mjs",
    "dev": "next --turbopack",
    "build": "next build && pagefind --site out --output-subdir _pagefind",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@mushi-mushi/brand": "workspace:*",
    "next": "^15.5.18",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
