# =============================================================================
# Mushi Mushi Docs Site — Environment Variables
# =============================================================================
#
# Build-time only. The docs site is a static export (next.config.mjs
# `output: 'export'`), so every NEXT_PUBLIC_* var below is INLINED into the
# client bundle at build time and shipped publicly. Only put values here that
# are safe to expose.
# =============================================================================

# --- Static-export base path / asset prefix (set by the deploy workflow) ---
# MUSHI_BASE_PATH=/mushi-mushi/docs
# MUSHI_ASSET_PREFIX=/mushi-mushi/docs

# --- Keyless "Try the demo" install on /connect (optional) -------------------
# When these are set, the public /connect page installs against a seeded,
# read-only demo project so visitors can try the MCP tools WITHOUT signing up.
#
# SECURITY: NEXT_PUBLIC_MUSHI_DEMO_API_KEY is inlined into the static bundle —
# it is intentionally PUBLIC. Mint it as an `mcp:read`-scoped key bound to a
# demo project that holds only synthetic seeded reports (see
# scripts/marketing/seed-demo.mjs). It can read nothing of real users, write
# nothing (mcp:read + the page forces ?read_only=1), and is rotatable: revoke
# and re-mint in the console if abused. Leave unset to fall back to the
# placeholder-key + "sign in to mint" flow.
#
# NEXT_PUBLIC_MUSHI_DEMO_API_KEY=mushi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_MUSHI_DEMO_API_ENDPOINT=https://dxptnwrhwsqckaftyymj.supabase.co/functions/v1/api
# NEXT_PUBLIC_MUSHI_DEMO_MCP_HTTP=https://dxptnwrhwsqckaftyymj.supabase.co/functions/v1/mcp
# NEXT_PUBLIC_MUSHI_DEMO_PROJECT_ID=00000000-0000-0000-0000-000000000000
# NEXT_PUBLIC_MUSHI_DEMO_PROJECT_NAME=mushi-demo
