# =============================================================================
# Mushi Mushi Admin Console — Environment Variables
# =============================================================================
#
# CLOUD MODE (default):
#   Leave all variables empty or delete this file entirely.
#   The console auto-connects to Mushi Mushi Cloud — no setup needed.
#   Just run `pnpm dev`, sign up, and start using.
#
# SELF-HOSTED MODE:
#   Set your own Supabase credentials below.
#   The console detects a non-cloud URL and switches to self-hosted mode
#   automatically. Set VITE_INSTANCE_TYPE=self-hosted to force it.
# =============================================================================

# --- Supabase (required for self-hosted, optional for cloud) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- API endpoint (optional — defaults to ${VITE_SUPABASE_URL}/functions/v1/api) ---
# VITE_API_URL=https://your-project-ref.supabase.co/functions/v1/api

# --- Instance type (optional — auto-detected from VITE_SUPABASE_URL) ---
# VITE_INSTANCE_TYPE=self-hosted

# --- Sentry error monitoring (optional) ---
# Leave blank to disable telemetry locally. The Sentry SDK no-ops when DSN
# is unset. DSNs are designed to be public — safe to bake into builds.
VITE_SENTRY_DSN=
# Set in CI to tag releases (e.g. the package version or commit SHA).
# VITE_RELEASE=
