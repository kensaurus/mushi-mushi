{
  "name": "@mushi-mushi/admin",
  "version": "0.2.0",
  "private": true,
  "description": "Mushi Mushi admin console — report triage, analytics dashboard, project settings",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @mushi-mushi/web build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src/",
    "lint:tokens": "node ../../scripts/check-design-tokens.mjs && node ../../scripts/audit-chip-contrast.mjs --strict && node ../../scripts/check-motion-properties.mjs && node ../../scripts/audit-page-scaffold.mjs --cluster",
    "audit:page-scaffold": "node ../../scripts/audit-page-scaffold.mjs",
    "audit:page-scaffold:cluster": "node ../../scripts/audit-page-scaffold.mjs --cluster --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@mushi-mushi/brand": "workspace:*",
    "@mushi-mushi/core": "workspace:*",
    "@mushi-mushi/marketing-ui": "workspace:*",
    "@mushi-mushi/mcp": "workspace:*",
    "@mushi-mushi/web": "workspace:*",
    "@sentry/react": "^10.59.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.11.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "rrweb": "^2.0.1",
    "streamdown": "^2.5.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-mushi-mushi": "workspace:*",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "apps/admin"
  }
}
