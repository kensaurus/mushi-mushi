{
  "name": "@mushi-mushi/admin",
  "version": "0.2.0",
  "private": true,
  "description": "Mushi Mushi admin console — report triage, analytics dashboard, project settings",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @mushi-mushi/web build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src/",
    "lint:tokens": "node ../../scripts/check-design-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mushi-mushi/brand": "workspace:*",
    "@mushi-mushi/core": "workspace:*",
    "@mushi-mushi/marketing-ui": "workspace:*",
    "@mushi-mushi/mcp": "workspace:*",
    "@mushi-mushi/web": "workspace:*",
    "@sentry/react": "^10.59.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.11.0",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "streamdown": "^2.5.0",
    "web-vitals": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mushi-mushi/eslint-config": "workspace:*",
    "@mushi-mushi/tsconfig": "workspace:*",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-mushi-mushi": "workspace:*",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "author": "Kenji Sakuramoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git",
    "directory": "apps/admin"
  }
}
