{
  "name": "mushi-mushi",
  "private": true,
  "description": "Bug translation for vibe coders — plain-English diagnosis + fix prompts via MCP. Open source.",
  "license": "MIT",
  "homepage": "https://github.com/kensaurus/mushi-mushi",
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/mushi-mushi.git"
  },
  "keywords": [
    "bug-translation",
    "vibe-coding",
    "mcp-server",
    "cursor",
    "bug-tracking",
    "user-feedback",
    "ai-triage",
    "developer-tools",
    "sdk",
    "error-monitoring",
    "sentry-companion",
    "knowledge-graph",
    "agentic-fix",
    "llm"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "build:console-knowledge": "node scripts/build-console-knowledge.mjs",
    "build": "turbo run build",
    "predev": "node scripts/kill-port.mjs 6464 && turbo daemon stop",
    "dev": "turbo run dev --force --concurrency=30 --log-prefix=none",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "size": "turbo run size",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "check:export-types-order": "node scripts/fix-export-types-order.mjs --check",
    "check:changeset-orphans": "node scripts/check-changeset-orphans.mjs",
    "check:secrets": "node scripts/check-no-secrets.mjs --all",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:catalog-sync": "node scripts/check-mcp-catalog-sync.mjs && node scripts/sync-mcp-tool-count.mjs --check",
    "sync:mcp-tool-count": "node scripts/sync-mcp-tool-count.mjs",
    "check:cursor-plugin": "node scripts/check-cursor-plugin.mjs",
    "check:mcp-publish-readiness": "node scripts/check-mcp-publish-readiness.mjs",
    "smoke:admin-health": "node scripts/admin-console-health.mjs",
    "smoke:activation-journey": "node scripts/activation-journey.mjs",
    "check:activation-contract": "node scripts/check-activation-contract.mjs",
    "check:migration-catalog": "node scripts/check-migration-catalog-sync.mjs",
    "gen:config-docs": "node scripts/generate-config-reference.mjs",
    "check:config-docs": "node scripts/check-config-docs.mjs",
    "check:community-files": "node scripts/sync-community-files.mjs --check",
    "sync:community-files": "node scripts/sync-community-files.mjs",
    "release": "pnpm sync:community-files && turbo run build && pnpm check:publish && pnpm check:migration-catalog && changeset publish",
    "changelog:aggregate": "node scripts/aggregate-changelogs.mjs",
    "changelog:check": "node scripts/aggregate-changelogs.mjs --check",
    "roadmap:bootstrap": "node scripts/bootstrap-roadmap.mjs",
    "pdca:loop": "node scripts/pdca-bounded-loop.mjs",
    "stripe:bootstrap": "node scripts/stripe-bootstrap.mjs",
    "prompts:bench": "node scripts/prompts-bench.mjs",
    "check:dead-buttons": "node scripts/check-dead-buttons.mjs",
    "check:publish": "node scripts/check-workspace-protocol.mjs && node scripts/check-packed-tarballs.mjs",
    "check:publish-readiness": "node scripts/check-publish-readiness.mjs",
    "check:license-headers": "node scripts/check-license-headers.mjs",
    "bootstrap:new-package": "node scripts/bootstrap-new-package.mjs",
    "sync:helm-migrations": "node scripts/sync-helm-migrations.mjs",
    "check:helm-migrations": "node scripts/sync-helm-migrations.mjs --check",
    "docs-stats": "node scripts/docs-stats.mjs --print-markdown",
    "check:docs-stats": "node scripts/docs-stats.mjs --check",
    "gen:sdk-version-matrix": "node scripts/gen-sdk-version-matrix.mjs",
    "check:sdk-version-matrix": "node scripts/gen-sdk-version-matrix.mjs --check",
    "check:internal-doc-links": "node scripts/check-internal-doc-links.mjs",
    "check:bundle-docs": "node scripts/check-bundle-docs.mjs",
    "gen:llms-txt": "node scripts/gen-llms-txt.mjs",
    "gen:mcp-tools-doc": "node scripts/gen-mcp-tools-doc.mjs",
    "check:onboarding-drift": "node scripts/check-onboarding-drift.mjs",
    "check:edge-fn-imports": "node scripts/check-edge-fn-imports.mjs",
    "bootstrap:new-npm-packages": "node scripts/bootstrap-publish-new-packages.mjs",
    "e2e": "pnpm --filter @mushi-mushi/e2e-dogfood e2e"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp",
      "sqlite3",
      "supabase"
    ],
    "overrides": {
      "undici@<6.24.0": ">=6.24.0",
      "@xmldom/xmldom@<0.9.10": ">=0.9.10",
      "uuid@<14.0.0": ">=14.0.0",
      "postcss@<8.5.10": ">=8.5.10",
      "next@<15.5.18": ">=15.5.18",
      "devalue@<5.8.1": ">=5.8.1",
      "hono@<4.12.25": ">=4.12.25",
      "ip-address@<=10.1.0": ">=10.1.1",
      "fast-uri@<3.1.2": ">=3.1.2",
      "mermaid@<11.15.0": ">=11.15.0",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "protobufjs@<=7.5.7": ">=7.5.8",
      "onnxruntime-web>protobufjs": ">=8.4.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "tar@<7": ">=7.4.3",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "ws@>=7.0.0 <7.5.11": ">=7.5.11",
      "ws@>=6.0.0 <6.2.4": ">=6.2.4",
      "shell-quote@<=1.8.3": ">=1.8.4",
      "react-router@>=7.0.0 <7.15.0": ">=7.15.0"
    },
    "patchedDependencies": {
      "nextra-theme-docs@4.6.1": "patches/nextra-theme-docs@4.6.1.patch"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "jiti": "^2.6.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.8"
  },
  "bugs": {
    "url": "https://github.com/kensaurus/mushi-mushi/issues"
  },
  "author": "Kenji Sakuramoto"
}
